{
  "expo": {
    "name": "Fortachones",
    "slug": "fortachones",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "fortachones",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0D0C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fortachones.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Fortachones needs the camera to capture workout evidence photos.",
        "NSPhotoLibraryUsageDescription": "Fortachones needs photo library access to attach workout evidence."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0D0C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.fortachones.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "androidStatusBar": {
      "backgroundColor": "#0B0D0C"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Fortachones to access your photos for workout evidence.",
          "cameraPermission": "Allow Fortachones to use the camera for workout evidence.",
          "microphonePermission": false
        }
      ],
      "expo-font",
      "expo-splash-screen"
    ]
  }
}
